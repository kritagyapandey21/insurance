# Backend Environment Variables
NODE_ENV=development
PORT=5000

# PostgreSQL Configuration
# Option 1: Use DATABASE_URL if you have a managed database URL
# DATABASE_URL=postgresql://user:password@host:port/database

# Option 2: Use individual connection parameters (used when DATABASE_URL is not set)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=insurance_user
POSTGRES_PASSWORD=StrongPass@123
POSTGRES_DB=insurance_db
POSTGRES_SSL=false

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Ethereum / Blockchain
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
ALCHEMY_KEY=your_alchemy_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# BEP20 (BSC) Configuration
BEP20_USDT_WALLET=0x9BBC6909Db28aC63516d4B60Eea3352ee0e3Ed5A

# TRC20 (Tron) Configuration
TRC20_USDT_WALLET=TWhjbs9JMTuhMTJTqGBcdydMPeef5f6ytd

# NOWPayments (alternative payment processor)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key

# Insurance Wallet Address (Primary - Ethereum)
INSURANCE_WALLET_ADDRESS=YOUR_ACTUAL_WALLET_ADDRESS_HERE

# Payment Verification Method: "etherscan", "web3", "bep20", "trc20", or "nowpayments"
PAYMENT_VERIFICATION_METHOD=etherscan

# Minimum confirmations required for payment
MIN_CONFIRMATIONS=12

# Web3 Configuration
WEB3_PROVIDER=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
WEB3_PRIVATE_KEY=your_private_key_for_signing_transactions

# Coverage Cleanup Job Interval (minutes)
COVERAGE_CLEANUP_INTERVAL_MINUTES=60
