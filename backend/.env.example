# Backend Environment Variables
NODE_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://insurance_user:StrongPass@123@127.0.0.1:5432/insurance_db
POSTGRES_SSL=false

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Ethereum / Blockchain
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
ALCHEMY_KEY=your_alchemy_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# NOWPayments (alternative payment processor)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key

# Insurance Wallet Address
INSURANCE_WALLET_ADDRESS=0x1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f90a1

# Payment Verification Method: "etherscan", "web3", or "nowpayments"
PAYMENT_VERIFICATION_METHOD=etherscan

# Minimum confirmations required for payment
MIN_CONFIRMATIONS=12

# Web3 Configuration
WEB3_PROVIDER=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key
WEB3_PRIVATE_KEY=your_private_key_for_signing_transactions
